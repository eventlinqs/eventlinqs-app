# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright mcp output and all screenshot artifacts — never commit
.playwright-mcp/
*.png
*.jpg
*.jpeg
*.webp

# Allowlist canonical media assets that ship with the app — these are
# production fallbacks, not screenshot artifacts, and MUST be tracked.
# See docs/MEDIA-ARCHITECTURE.md.
!public/images/hero/*.jpg
!public/images/hero/*.jpeg
!public/images/hero/*.webp
!public/images/hero/*.png
!public/**/*.svg

# playwright test runner artifacts — local only
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# local utility scripts (screenshots, one-off probes)
/scratch/

# lighthouse audit reports — local only
lighthouse-reports/
.lighthouse/

# Claude Code local settings
.claude/

supabase/.temp/

.vercel
