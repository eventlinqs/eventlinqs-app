# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.staging.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright mcp output and all screenshot artifacts — never commit
.playwright-mcp/
*.png
*.jpg
*.jpeg
*.webp

# Allowlist canonical media assets that ship with the app — these are
# production fallbacks, not screenshot artifacts, and MUST be tracked.
# See docs/MEDIA-ARCHITECTURE.md.
!public/images/hero/*.jpg
!public/images/hero/*.jpeg
!public/images/hero/*.webp
!public/images/hero/*.png
!public/**/*.svg

# Allowlist Pre-Task 2 visual regression evidence - BEFORE/AFTER screenshots
# captured at 7 viewports per refactor. Tracked as proof of "no visual
# regression" for each migration commit; reviewers can diff before/ vs after/.
!docs/visual-regression/**/*.png
!docs/visual-regression/**/*.jpg
!docs/visual-regression/**/*.jpeg
!docs/visual-regression/**/*.webp

# Allowlist Pre-Task 3 visual regression evidence under sprint1/phase-1b
# (iter-N/screenshots-*-after, etc). Same rationale: tracked as proof that
# the ISR refactor preserved visual integrity across viewports.
!docs/sprint1/phase-1b/**/*.png
!docs/sprint1/phase-1b/**/*.jpg
!docs/sprint1/phase-1b/**/*.jpeg
!docs/sprint1/phase-1b/**/*.webp

# Allowlist Batch 4 visual quality gate evidence (before/after screenshots)
!docs/redesign/**/*.png
!docs/redesign/**/*.jpg
!docs/redesign/**/*.jpeg
!docs/redesign/**/*.webp

# playwright test runner artifacts — local only
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# local utility scripts (screenshots, one-off probes)
/scratch/

# lighthouse audit reports — local only
lighthouse-reports/
.lighthouse/

# Claude Code local settings
.claude/

supabase/.temp/

.vercel

# Playwright auth state (test session cookies, tokens)
.auth/

# Local scratch state (e.g. M6 Phase 2 E2E orchestrator state)
.tmp/

# Local diagnostic scratch (forensic dumps, ad-hoc verification
# scripts, screenshot evidence). Anything reusable should be promoted
# to tests/e2e/ or docs/. Convention established 2026-05-24 after PR #34.
.diagnostic/
.diagnostic-*.log
.diagnostic-*.html

.vercel

# Batch 9.2.1 test-user credentials (local-only)
docs/redesign/batch-9-2-1-evidence/test-user-credentials.md

# Batch 10 - migration debug logs (local-only)
migration-debug.log
*.migration.log
docs/redesign/batch-*-evidence/lighthouse/*.json

# Competitor research screenshots are committed deliverables (overrides *.png)
!research/competitors/**/*.png

# Iteration snapshot screenshots are committed deliverables (overrides *.png)
!research/snapshots/**/*.png

# Local Playwright tickets-spine fixture (seeded test data, never commit)
tests/e2e/.ticket-fixture.json

design-captures/
scripts/design-capture.mjs
scripts/axe-scene.mjs
