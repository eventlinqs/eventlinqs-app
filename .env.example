# EventLinqs — environment template.
# Copy to .env.local and fill in real values. .env.local is git-ignored.

# ---------------------------------------------------------------------------
# Supabase (required) — URL + keys from the Supabase project dashboard.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Bypasses RLS — never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: preview-environment Supabase project (Phase 2.5 deliverable B).
# When the *_PREVIEW vars are populated (typically only in Vercel preview
# environment), the resolver in src/lib/supabase/env.ts uses them in place
# of the base values above. Production deploys must leave these unset.
# See docs/hardening/phase2-5/preview-supabase-setup.md for setup steps.
NEXT_PUBLIC_SUPABASE_URL_PREVIEW=
NEXT_PUBLIC_SUPABASE_ANON_KEY_PREVIEW=
SUPABASE_SERVICE_ROLE_KEY_PREVIEW=

# ---------------------------------------------------------------------------
# Google Maps (required for /events?view=map and /events/[slug] venue map).
# Create a Maps JavaScript API key at
# https://console.cloud.google.com/google/maps-apis/credentials.
# The map gracefully degrades to a "temporarily unavailable" notice when
# this is unset, so local dev without the key still builds.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Pexels (optional). If unset, event cards fall back to the branded SVG
# placeholder instead of category-appropriate Pexels photos.
# ---------------------------------------------------------------------------
PEXELS_API_KEY=

# ---------------------------------------------------------------------------
# Branded storage domain (Batch 10).
# When set, every user-facing storage URL routes through this hostname
# instead of leaking the Supabase project domain. Set to
# `images.eventlinqs.com` once the Supabase Storage custom-domain
# config + DNS resolution is in place. Leave blank in dev so URLs fall
# back to the Supabase URL pattern.
# Eventbrite uses img.evbuc.com; Ticketmaster uses s1.ticketm.net;
# DICE uses dice-media.imgix.net; Airbnb uses a0.muscache.com. No
# major event platform exposes its origin storage hostname.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STORAGE_DOMAIN=

# ---------------------------------------------------------------------------
# Stripe (required for checkout).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Upstash Redis (required for inventory cache and rate limiting in production).
# Production target: Fixed 250 MB plan, region ap-southeast-2 (Sydney).
# Health check at /api/_health/redis must report latencyMs < 20 from
# Sydney compute. See docs/hardening/phase1/upstash-sydney-setup.md.
# Local dev may run without these set; the client logs a warning and the
# limiter / inventory cache fail open via Postgres fallback.
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Resend (required for production transactional and auth confirmation emails).
# Auth confirmation, password reset, and other transactional sends are now
# driven directly via the Resend SDK from /api/auth/* (see
# src/lib/email/auth-emails.ts). This bypasses Supabase Auth's outbound SMTP,
# which had a 4-emails-per-hour project-wide cap that silently dropped
# confirmation mail under load in production.
# EMAIL_FROM must be a verified Resend domain identity (e.g. EventLinqs
# <hello@eventlinqs.com>). Local dev defaults to that string; production
# should set explicitly.
# See docs/hardening/phase1/resend-smtp-setup.md.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=

# ---------------------------------------------------------------------------
# Sentry (required for production observability). DSN is the project-scoped
# ingestion endpoint, NOT a secret in the strict sense (it ships in client
# bundles) but rotation policy is documented separately. Auth token is used
# only at build time for source map upload.
# See docs/hardening/phase1/sentry-setup.md.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---------------------------------------------------------------------------
# HOMEPAGE_SEED_FIXTURE - homepage density fixture (PREVIEW + local ONLY).
# Set to "1" to render the homepage from the local 55-event catalogue fixture
# instead of the live database, so the page can be benchmarked at full,
# Ticketmaster-rival density while staging is not yet provisioned.
#
# On Vercel: set this ONLY as a PREVIEW-environment variable. The prebuild step
# (scripts/prebuild-fixture.mjs) regenerates the fixture at build time and
# next.config traces it into the homepage bundle so preview deployments render
# the full catalogue.
#
# HARD RULE: NEVER set this in the PRODUCTION environment. The prebuild step
# aborts the build if it sees the flag with VERCEL_ENV=production, and
# loadHomeUpcoming ignores the flag in production as a second guard. Production
# always serves real data.
# ---------------------------------------------------------------------------
HOMEPAGE_SEED_FIXTURE=
