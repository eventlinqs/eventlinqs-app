# EventLinqs — environment template.
# Copy to .env.local and fill in real values. .env.local is git-ignored.

# ---------------------------------------------------------------------------
# Supabase (required) — URL + keys from the Supabase project dashboard.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Bypasses RLS — never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Google Maps (required for /events?view=map and /events/[slug] venue map).
# Create a Maps JavaScript API key at
# https://console.cloud.google.com/google/maps-apis/credentials.
# The map gracefully degrades to a "temporarily unavailable" notice when
# this is unset, so local dev without the key still builds.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Pexels (optional). If unset, event cards fall back to the branded SVG
# placeholder instead of category-appropriate Pexels photos.
# ---------------------------------------------------------------------------
PEXELS_API_KEY=

# ---------------------------------------------------------------------------
# Stripe (required for checkout).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
