# EventLinqs — environment template.
# Copy to .env.local and fill in real values. .env.local is git-ignored.

# ---------------------------------------------------------------------------
# Supabase (required) — URL + keys from the Supabase project dashboard.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Bypasses RLS — never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Google Maps (required for /events?view=map and /events/[slug] venue map).
# Create a Maps JavaScript API key at
# https://console.cloud.google.com/google/maps-apis/credentials.
# The map gracefully degrades to a "temporarily unavailable" notice when
# this is unset, so local dev without the key still builds.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Pexels (optional). If unset, event cards fall back to the branded SVG
# placeholder instead of category-appropriate Pexels photos.
# ---------------------------------------------------------------------------
PEXELS_API_KEY=

# ---------------------------------------------------------------------------
# Stripe (required for checkout).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Upstash Redis (required for inventory cache and rate limiting in production).
# Production target: Fixed 250 MB plan, region ap-southeast-2 (Sydney).
# Health check at /api/_health/redis must report latencyMs < 20 from
# Sydney compute. See docs/hardening/phase1/upstash-sydney-setup.md.
# Local dev may run without these set; the client logs a warning and the
# limiter / inventory cache fail open via Postgres fallback.
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Resend (required for production transactional and Supabase Auth SMTP).
# Resend SMTP credentials are configured inside the Supabase Dashboard
# rather than via env vars; this RESEND_API_KEY is only consumed by direct
# Resend SDK calls (e.g. /api/contact in M11). See
# docs/hardening/phase1/resend-smtp-setup.md.
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Sentry (required for production observability). DSN is the project-scoped
# ingestion endpoint, NOT a secret in the strict sense (it ships in client
# bundles) but rotation policy is documented separately. Auth token is used
# only at build time for source map upload.
# See docs/hardening/phase1/sentry-setup.md.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
