# EventLinqs - STAGING environment template.
#
# This is the env contract for the load-test staging rig described in
# docs/SCALE-AND-LOAD-TEST-PLAN.md (section 2) and provisioned via
# docs/staging/PROVISIONING-RUNBOOK.md.
#
# Staging is a FULL PARALLEL STACK. Every value below must point at a
# staging-only resource, never a production one. Production is never the
# target of a load test. Copy to .env.staging (git-ignored) and fill in the
# values captured during provisioning.
#
# The single most important rule: the Supabase URL/keys here must be the
# STAGING project ref, NOT the production ref. The seed script
# (scripts/staging-seed.mjs) hard-refuses to run against the production ref
# as a safety net, but the first line of defence is this file.

# ---------------------------------------------------------------------------
# Supabase - STAGING project (separate Sydney project, same region as prod).
# From the staging project's dashboard: Settings > API.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Bypasses RLS - never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=
# DB password for `supabase db push --linked` against the staging project.
SUPABASE_DB_PASSWORD_STAGING=

# Used by scripts/staging-seed.mjs (the load-test drop-event seed). These may
# simply mirror the two values above; they exist as distinct names so the seed
# script can assert it is pointed at staging and never at prod.
STAGING_SUPABASE_URL=
STAGING_SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Stripe - TEST MODE ONLY on staging. Use a separate restricted test key set
# and a separate webhook endpoint pointed at the staging deployment. A load
# test must never be able to create a real charge.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Upstash Redis - separate STAGING database, region ap-southeast-2 (Sydney),
# same plan as the production target so throughput numbers are honest.
# Must NOT share keys with the production Redis (no shared rate-limit or
# inventory-cache namespace).
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Cron secret - protects the scheduled routes (reservation-expire,
# waitlist-expire, squad-expire, queue-admit). Use a staging-only value.
# ---------------------------------------------------------------------------
CRON_SECRET=

# ---------------------------------------------------------------------------
# Resend - sandbox / suppressed-send key on staging. A load test must not fan
# out tens of thousands of real confirmation emails.
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Sentry - staging project or environment tag `staging`, so staging load-test
# errors never page the production on-call.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_ENVIRONMENT=staging

# ---------------------------------------------------------------------------
# Maps / Mapbox / Pexels - reuse the existing keys (read-only, public, no
# load-bearing scale role). Restrict the Mapbox/Maps key to the staging
# domain in the respective console.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
PEXELS_API_KEY=

# ---------------------------------------------------------------------------
# App - staging public URL.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://staging.eventlinqs.com
NEXT_PUBLIC_APP_NAME=EventLinqs (staging)
