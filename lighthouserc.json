{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/events",
        "http://localhost:3000/events/browse/melbourne",
        "http://localhost:3000/categories/afrobeats",
        "http://localhost:3000/events/afrobeats-melbourne-summer-sessions",
        "http://localhost:3000/organisers",
        "http://localhost:3000/pricing",
        "http://localhost:3000/help",
        "http://localhost:3000/legal/terms",
        "http://localhost:3000/login",
        "http://localhost:3000/signup"
      ],
      "_authNote": "All listed URLs verified to render without auth (HTTP 200, no redirect). Auth-gated surfaces - /dashboard/*, /admin/*, /orders/[order_id]/confirmation, /squad/[token], /verify-email-sent - are excluded from this gate because Lighthouse cannot pass session cookies/JWTs reliably in CI. Module M7 (admin) and Pre-Task 5 (checkout/orders perf) will each add their own auth-context Lighthouse gate using a recorded session.",
      "numberOfRuns": 1,
      "settings": {
        "formFactor": "mobile",
        "preset": "perf",
        "chromeFlags": "--headless=new --no-sandbox --disable-gpu --disable-dev-shm-usage",
        "extraHeaders": "{\"Cookie\":\"el-audit=1\"}"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.80 }],
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:best-practices": ["error", { "minScore": 1.0 }],
        "categories:seo": ["error", { "minScore": 1.0 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4000 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 600 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "speed-index": ["warn", { "maxNumericValue": 4500 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
