{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/events",
        "http://localhost:3000/events/browse/melbourne",
        "http://localhost:3000/events/afrobeats-melbourne-summer-sessions",
        "http://localhost:3000/categories/afrobeats"
      ],
      "numberOfRuns": 1,
      "settings": {
        "formFactor": "mobile",
        "throttlingMethod": "simulate",
        "screenEmulation": {
          "mobile": true,
          "width": 412,
          "height": 823,
          "deviceScaleFactor": 1.75
        },
        "emulatedUserAgent": "Mozilla/5.0 (Linux; Android 11; Pixel 5) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/130 Mobile Safari/537.36",
        "chromeFlags": "--headless=new --no-sandbox --disable-gpu --disable-dev-shm-usage",
        "extraHeaders": "{\"Cookie\":\"el-audit=1\"}"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.65 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 1.0 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.05 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 6000 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 500 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1500 }],
        "speed-index": ["warn", { "maxNumericValue": 7000 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
